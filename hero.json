.hero-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
    gap:20px;
    margin-top:20px;
}

.hero-api-card{
    background:#0f172a;
    border-radius:15px;
    overflow:hidden;
    text-align:center;
    padding-bottom:15px;
    transition:.3s;
}

.hero-api-card:hover{
    transform:translateY(-5px);
}

.hero-api-card img{
    width:100%;
    height:220px;
    object-fit:cover;
}

.hero-api-card h4{
    margin:10px 0;
}

.hero-api-card p{
    margin:5px 0;
}
